# 智能分类器环境配置示例文件
# 复制此文件为 .env 并根据实际情况修改配置

# 应用配置
CLASSIFIER_APP_NAME=智能分类器
CLASSIFIER_APP_VERSION=2.0.0
CLASSIFIER_DEBUG=false

# 服务器配置
CLASSIFIER_HOST=0.0.0.0
CLASSIFIER_PORT=8010

# LLM配置
CLASSIFIER_LLM_PROVIDER=local_vllm
CLASSIFIER_LLM_API_KEY=vllm
CLASSIFIER_LLM_BASE_URL=http://localhost:8000/v1
CLASSIFIER_LLM_MODEL=/root/autodl-tmp/models/Qwen3-8b-AWQ
CLASSIFIER_LLM_TEMPERATURE=0.1
CLASSIFIER_LLM_MAX_TOKENS=512
CLASSIFIER_LLM_TIMEOUT=60

# 默认分类任务
CLASSIFIER_DEFAULT_TASK=risk_assessment

# 文件处理配置
CLASSIFIER_MAX_FILE_SIZE=10485760  # 10MB
CLASSIFIER_UPLOAD_PATH=uploads
CLASSIFIER_OUTPUT_PATH=outputs

# 缓存配置
CLASSIFIER_ENABLE_CACHE=true
CLASSIFIER_CACHE_TTL=3600

# 外部API密钥（如果使用在线服务）
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
QWEN_API_KEY=your_qwen_api_key_here
