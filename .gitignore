# AgentD — project-level gitignore

# Runtime PID and log files (created by startup scripts)
.pids/
.logs/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/
.coverage
.coverage.*
.mypy_cache/
.ruff_cache/

# Environment secrets
.env
*.env
*.env.local

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Node
node_modules/
.next/
.turbo/

# Debug output
debug/
.playwright-mcp/
*.log

# Project-local runtime and generated artifacts
agentd/.env
agentd/.venv/
agentd/__pycache__/
agentd/.pytest_cache/
agentd/.coverage
agentd/.coverage.*
web/.env.local
web/node_modules/
web/.next/
web/.turbo/

# Local docs / planning files kept out of GitHub baseline
docs/
AGENTD_CONTRACT.md
AGENTS.md
CLAUDE.md
frontdesign.md
API_GUIDE.md

# Claude Code local config
.claude/

# Local skill development (root-level only, not agentd/skills/)
/skills/

# Domain extension packages are managed in their own repos.
/extensions/

# Local benchmark/export bundles.
/outputs/

# v0.4.5 private insurance clause extension artifacts; these move to the
# extension repo rather than the open-source AgentD main repo.
agentd/db/alembic/versions/016_insurance_clause_library.py
agentd/tests/test_v045_clause_import_extension.py
agentd/tests/test_v045_clause_batch_compare_skill.py
web/components/extensions/Clause*.tsx
web/app/extensions/*/import/

# Design reference (local only)
AgentD-Design-Reference/
/drafts_login_hero/
agentd-login-logo-enter-fix.png

# Local database files
*.db

# Research notes (local only)
research/

# CLI service registry — local runtime truth with absolute paths (use cli_registry.example.json as template)
agentd/cli_registry.json

# Local skill package staging artifacts (root-level)
/employee-risk-skill-package/
/pdf-rename-skill-package/
/ocr-to-markdown-skill-package/
/packaging/ocr-cli-service/
/packaging/skill-packages/
/services/

# Frontend build output for external sample services
services/**/dist/
