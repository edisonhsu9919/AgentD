# ═══════════════════════════════════════════════════════════════════════════════
# AgentD Environment Configuration (.env.example)
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your real values.
# See docs/env/ for ready-to-use templates (local dev / server deploy).
#
# Legend:
#   [REQUIRED]    — must be set for the system to function
#   [RECOMMENDED] — should be set; has a safe default but review it
#   [OPTIONAL]    — has a sensible default; override only if needed

# ── Database [REQUIRED] ─────────────────────────────────────────────────────
# Async PostgreSQL connection URL.
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/agentd

# ── JWT [REQUIRED for production] ───────────────────────────────────────────
# MUST change SECRET_KEY before deploying to production.
SECRET_KEY=change-me-in-production
# [OPTIONAL] Token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── LLM (OpenAI-compatible API) [REQUIRED] ─────────────────────────────────
# Supports: local llama.cpp, vLLM, OpenRouter, DeepSeek, MiniMax, etc.
# After Phase I2, DB model config takes priority; these become fallback.
#
# Example — local llama.cpp:
#   LOCAL_LLM_URL=http://localhost:8080/v1
#   LLM_API_KEY=no-key
#   DEFAULT_MODEL_ID=qwen3-30b
#
# Example — MiniMax online:
#   LOCAL_LLM_URL=https://api.minimaxi.com/v1
#   LLM_API_KEY=your-api-key
#   DEFAULT_MODEL_ID=MiniMax-M2.5
#
LOCAL_LLM_URL=http://localhost:8080/v1
LLM_API_KEY=no-key
DEFAULT_MODEL_ID=local-default
# [OPTIONAL] Context window size in tokens
CONTEXT_WINDOW_TOKENS=32768

# ── Workspace [REQUIRED] ───────────────────────────────────────────────────
# Parent directory for all user workspaces.
# Each user gets: <WORKSPACE_ROOT>/<username>/
# Catalog lives at: <WORKSPACE_ROOT>/_catalog/
WORKSPACE_ROOT=/tmp/agentd/workspaces

# ── DB Connection Pool [OPTIONAL] ──────────────────────────────────────────
# Per-process settings. Total DB connections = pool_size * num_workers.
# Tune based on expected concurrency and DB max_connections.
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Seed Admin [RECOMMENDED] ──────────────────────────────────────────────
# Created on first startup ONLY if the users table is empty.
# This is NOT a permanent admin — manage admins via the user management API.
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123

# ── App [OPTIONAL] ─────────────────────────────────────────────────────────
# Set DEBUG=true for local development only. Never in production.
DEBUG=false
